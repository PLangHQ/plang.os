# Large build artifacts that live outside the repo.
# See container/build.sh for how the zip is sourced (defaults to
# /shared/plang-amd64.zip, overridable with PLANG_ZIP env var).
container/plang-*.zip

# Local PLang build output — generated by `plang build`, rebuilt from the
# .goal files in the repo.
.build/

# Bot output lives on feature branches, not main — but tracked in PRs per
# CLAUDE.md. Don't ignore .bot/.
